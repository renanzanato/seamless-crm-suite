{
  "manifest_version": 3,
  "name": "Pipa Driven",
  "version": "1.0.0",
  "description": "Espelho WhatsApp Web para o CRM Pipa Driven",
  "permissions": ["storage", "tabs", "activeTab", "scripting", "alarms"],
  "host_permissions": [
    "https://web.whatsapp.com/*",
    "https://dsvkoeomtnwccxxcwwga.supabase.co/*",
    "https://cdn.jsdelivr.net/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["lib/wa-bridge.js", "lib/capture-panel.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js", "inject-wa.js", "vendor/wppconnect-wa.js"],
      "matches": ["https://web.whatsapp.com/*"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
